{
  "name": "session-box",
  "version": "0.0.2",
  "description": "多账号浏览器工具，支持 partition 隔离、代理管理、拖拽排序",
  "author": "hunmer",
  "packageManager": "pnpm@10.17.1",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "node scripts/build-production.js local",
    "pack:release": "node scripts/build-production.js release",
    "pack:dir": "npx electron-vite build && npx electron-builder --config electron-builder.json --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@vueuse/core": "^12.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "lucide-vue-next": "^0.460.0",
    "pinia": "^2.3.0",
    "radix-vue": "^1.9.11",
    "reka-ui": "^2.9.5",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.3.1",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.3.9",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-vue-devtools": "^8.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "vue-demi"
    ]
  }
}
