{
  "appId": "com.session-box.app",
  "productName": "SessionBox",
  "directories": {
    "output": "dist-app"
  },
  "fileAssociations": [
    {
      "ext": [
        "htm",
        "html",
        "shtml",
        "xht",
        "xhtml"
      ],
      "name": "HTML File",
      "mimeType": "text/html"
    }
  ],
  "protocols": [
    {
      "name": "HTTP",
      "schemes": [
        "http"
      ]
    },
    {
      "name": "HTTPS",
      "schemes": [
        "https"
      ]
    }
  ],
  "files": [
    "out/**/*",
    "package.json",
    "node_modules/**/*",
    "!node_modules/**/{README.md,readme.md,README,readme,CHANGELOG.md,CHANGELOG,LICENSE,license,LICENSE.md,.npmignore,.editorconfig,.eslintrc,.eslintrc.js,.eslintrc.json,.eslintrc.yml}",
    "!node_modules/.bin",
    "!node_modules/**/*.{md,ts,map,d.ts}",
    "!node_modules/**/{test,tests,__tests__,example,examples,docs,doc,website,.github,.vscode}"
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "icon": "resources/icon.icns",
    "category": "public.app-category.productivity"
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "win": {
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "resources/icon.png",
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "include": "build/installer.nsh"
  },
  "extraResources": [
    {
      "from": "resources/icon.png",
      "to": "icon.png"
    },
    {
      "from": "resources/trayIcon.png",
      "to": "trayIcon.png"
    },
    {
      "from": "resources/trayIconTemplate@2x.png",
      "to": "trayIconTemplate@2x.png"
    },
    {
      "from": "resources/unknow.ico",
      "to": "unknow.ico"
    },
    {
      "from": "win_packages",
      "to": "win_packages",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "mac_packages",
      "to": "mac_packages",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "resources/plugins",
      "to": "plugins",
      "filter": [
        "**/*"
      ]
    }
  ],
  "compression": "store",
  "asar": true,
  "publish": {
    "provider": "github",
    "owner": "hunmer",
    "repo": "sessionBox"
  }
}
